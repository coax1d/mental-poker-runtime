{
  "name": "exploding-kittens-mental-poker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:wasm": "wasm-pack build ../../mental-poker/play --target web --features wasm && rm -rf src/wasm/pkg && cp -r ../../mental-poker/play/pkg src/wasm/pkg",
    "setup:papi": "node scripts/papi-add.mjs",
    "setup": "npm run build:wasm && npm run setup:papi"
  },
  "dependencies": {
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd": "^0.0.11",
    "@polkadot-labs/hdkd-helpers": "^0.0.13",
    "polkadot-api": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.4.0"
  }
}
