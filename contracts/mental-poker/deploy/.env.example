# Copy to .env and fill in. .env is gitignored.

# Required — deployer account (must hold PAS on Paseo Asset Hub).
PASSET_HUB_MNEMONIC="word1 word2 ... word12"
PASSET_HUB_ADDRESS="13xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional — only needed for the test-flow / map-player2 scripts that exercise
# a second player from Node side. The client app does not read these.
# PLAYER2_MNEMONIC="word1 word2 ... word12"

# Optional — override the Paseo Asset Hub WS endpoint.
# PASSET_HUB_WS="wss://sys.ibp.network/asset-hub-paseo"
