# Copy to `.env` and fill in. `.env` is gitignored.
#
# Populated by `npm run gen-account`.
PASSET_HUB_MNEMONIC=
PASSET_HUB_ADDRESS=

# Optional override — defaults to wss://sys.ibp.network/asset-hub-paseo.
# The original wss://testnet-passet-hub.polkadot.io endpoint is dead.
# Other working endpoints (probed 2026-04-09):
#   wss://asset-hub-paseo-rpc.n.dwellir.com
#   wss://asset-hub-paseo.dotters.network
PASSET_HUB_WS=wss://sys.ibp.network/asset-hub-paseo
